MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-M2.7
# China-region keys often use https://api.minimaxi.com/v1
# Global keys often use https://api.minimax.io/v1
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
PORT=4173
COLLAB_MODE=server
COLLAB_PROVIDER=local-file
COLLAB_REALTIME=false
COLLAB_PRESENCE=false
COLLAB_LOCAL_CACHE=true
BOARD_STORE_DIR=.data/boards
